pipeline {

    agent any

environment {
    IMAGE_NAME = "alexdocker159/amazingfacts"
}

stages {

    stage('Clone Repository') {
        steps {
            git 'https://github.com/AftabSahil/amazingfacts.git'
        }
    }

    stage('Build Docker Image') {
        steps {
            sh 'docker buildx build --platform linux/amd64 -t $IMAGE_NAME:latest --push .
        }
    }

    stage('Terraform Init') {
        steps {
            sh '''
            cd terraform
            terraform init
            '''
        }
    }

    stage('Terraform Apply') {
        steps {
            sh '''
            cd terraform
            terraform apply -auto-approve
            '''
        }
    }

}
```

}
